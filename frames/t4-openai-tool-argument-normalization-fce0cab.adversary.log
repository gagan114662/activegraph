## Breakage discovered

Invalid OpenAI `tool_calls[].function.arguments` can still execute a tool successfully when the tool input schema has zero declared fields, because `_extract_tool_calls` encodes invalid/non-object arguments as `{"_raw": ...}` and Pydantic `BaseModel` ignores extra fields by default.

That means the new regression only proves invalid args fail for a schema with a required field (`query: str`). It does not guarantee the promised invariant: invalid JSON and decoded non-objects flow to `tool.invalid_input` and cannot invoke the tool.

Additional edge: empty string arguments are coerced to `{}` by:

```python
arguments = _value(function, "arguments") or "{}"
```

so `""` is treated as a valid empty JSON object instead of invalid JSON.

## Interpreter-backed reproduction

Command:

```sh
python3 - <<'PY'
from __future__ import annotations
from types import SimpleNamespace
from typing import Any
from pydantic import BaseModel
from activegraph import FrozenClock, Graph, IDGen, Runtime, clear_registry, clear_tool_registry, llm_behavior, tool
from activegraph.llm import OpenAIProvider

class EmptyArgs(BaseModel):
    pass
class PingResult(BaseModel):
    ok: bool
class Answer(BaseModel):
    answer: str

def run(arguments: str):
    clear_registry(); clear_tool_registry()
    @tool(name='ping', description='No-arg ping.', input_schema=EmptyArgs, output_schema=PingResult, deterministic=True)
    def ping(args: EmptyArgs, ctx: Any) -> PingResult:
        return PingResult(ok=True)
    @llm_behavior(name='answer_with_ping', on=['goal.created'], description='Answer with ping.', output_schema=Answer, tools=[ping], max_tool_turns=2, temperature=0.0)
    def answer_with_ping(event: Any, graph: Any, ctx: Any, out: Answer) -> None:
        graph.add_object('answer', {'answer': out.answer})
    first = SimpleNamespace(choices=[SimpleNamespace(message=SimpleNamespace(content=None, tool_calls=[SimpleNamespace(id='call_1', type='function', function=SimpleNamespace(name='ping', arguments=arguments))]), finish_reason='tool_calls')], usage=SimpleNamespace(prompt_tokens=5, completion_tokens=2), model='gpt-4o-mini')
    final = SimpleNamespace(choices=[SimpleNamespace(message=SimpleNamespace(content='{"answer":"done"}'), finish_reason='stop')], usage=SimpleNamespace(prompt_tokens=6, completion_tokens=3), model='gpt-4o-mini')
    client = SimpleNamespace(chat=SimpleNamespace(completions=SimpleNamespace(calls=[], _responses=[first, final])))
    def create(**kwargs):
        client.chat.completions.calls.append(kwargs)
        return client.chat.completions._responses.pop(0)
    client.chat.completions.create = create
    graph = Graph(ids=IDGen(), clock=FrozenClock('2026-05-22T12:00:00Z'), run_id='t4-adversary')
    Runtime(graph, llm_provider=OpenAIProvider(client=client), budget={'max_tool_calls': 4}).run_goal('g')
    return [(e.type, e.payload.get('reason'), e.payload.get('tool'), e.payload.get('args'), e.payload.get('object')) for e in graph.events]

for arg in ['', '{', '1', '"not an object"']:
    print('ARGS', repr(arg))
    for row in run(arg):
        print(row)
PY
```

