def classify(inner_path):
    full='activegraph/'+inner_path
    rwm=[raw for p,m,raw in perms if m=='rw' and matches(p, full)]
    rom=[raw for p,m,raw in perms if m=='ro' and matches(p, full)]
    if rwm: return 'IN_SCOPE_RW', ';'.join(rwm)
    if rom: return 'OUT_OF_SCOPE_RO_CHANGED', ';'.join(rom)
    return 'OUT_OF_SCOPE_NO_MATCH', '-'
print('outer')
print(subprocess.check_output(['git','-C',str(outer),'log','-1','--oneline'], text=True).strip())
print(subprocess.check_output(['git','-C',str(outer),'status','-sb'], text=True).rstrip())
