    print(subprocess.check_output(cmd, text=True).rstrip())
print('ahead_diff_permission_classifier')
out=subprocess.check_output(['git','-C',str(outer/'activegraph'),'diff','--name-only','origin/main...HEAD'], text=True).splitlines()
for p in out:
    status, pats=classify(p)
    print(f'{p}\t{status}\t{pats}')
print('dirty_permission_classifier')
out=subprocess.check_output(['git','-C',str(outer/'activegraph'),'diff','--name-only'], text=True).splitlines()
